\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces Actual crypto stress-prediction task. The target is whether the next 10-day equal-weight crypto basket return is below $-7\%$. Online weighting gives the best log loss, Brier score, AUC, and concentration of realized stress events in the top-risk quartile. The risk-off strategy is included as an interpretable diagnostic rather than a production trading rule.}}{8}{table.1}\protected@file@percent }
\newlabel{tab:actual-crypto-risk}{{1}{8}{Actual crypto stress-prediction task. The target is whether the next 10-day equal-weight crypto basket return is below $-7\%$. Online weighting gives the best log loss, Brier score, AUC, and concentration of realized stress events in the top-risk quartile. The risk-off strategy is included as an interpretable diagnostic rather than a production trading rule}{table.1}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Predicted next-block crypto stress probabilities. Red vertical markers indicate realized future stress blocks. The online score is a real-time risk signal, not a direct price forecast.}}{8}{figure.2}\protected@file@percent }
\newlabel{fig:actual-crypto-risk-probs}{{2}{8}{Predicted next-block crypto stress probabilities. Red vertical markers indicate realized future stress blocks. The online score is a real-time risk signal, not a direct price forecast}{figure.2}{}}
